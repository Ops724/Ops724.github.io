<article class="article article-post">
  <header class="article-header">
    <h1><%= page.title %></h1>
    <%- partial('partials/post-meta') %>
    <%- partial('partials/language-switcher') %>
  </header>
  <div class="article-body">
    <%- page.content %>
  </div>
  <%- partial('partials/pagination', { neighbors: post_neighbors(page) }) %>
</article>
