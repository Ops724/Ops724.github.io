<% const currentLang = page_lang(page); %>
<div class="language-switcher">
  <a href="<%- localized_page_url(page, 'zh-CN') %>" class="<%= currentLang === 'zh-CN' ? 'is-active' : '' %>">
    <%= __('ui.language_zh') %>
  </a>
  <a href="<%- localized_page_url(page, 'en') %>" class="<%= currentLang === 'en' ? 'is-active' : '' %>">
    <%= __('ui.language_en') %>
  </a>
</div>
