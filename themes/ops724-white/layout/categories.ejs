<section class="content-section">
  <header class="section-heading">
    <h1><%= page.title %></h1>
    <p><%= __('ui.categories_intro') %></p>
  </header>
  <div class="taxonomy-list">
    <% const currentLang = page_lang(page); %>
    <% site.categories.sort('name').forEach(function(category) { %>
      <% const count = taxonomy_count_by_lang(category, currentLang); %>
      <% if (count > 0) { %>
        <a class="taxonomy-item" href="<%- localized_taxonomy_url(category.path, currentLang) %>">
          <span><%= category.name %></span>
          <span><%= count %></span>
        </a>
      <% } %>
    <% }) %>
  </div>
  <div class="article-body">
    <%- page.content %>
  </div>
</section>
