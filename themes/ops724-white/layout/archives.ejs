<section class="content-section">
  <header class="section-heading">
    <h1><%= page.title || config.title %></h1>
    <% if (page.content) { %>
      <div class="section-copy">
        <%- page.content %>
      </div>
    <% } %>
  </header>

  <% const groups = archive_groups(page.posts || []); %>

  <% if (groups.length) { %>
    <div class="archive-groups">
      <% groups.forEach(function(group) { %>
        <section class="archive-group">
          <h2 class="archive-group-title"><%= group.year %>.<%= group.month %></h2>
          <div class="archive-list">
            <% group.posts.forEach(function(post) { %>
              <article class="archive-item">
                <p class="archive-item-date"><%= date(post.date, 'MM-DD') %></p>
                <div class="archive-item-body">
                  <h3><a href="<%- url_for(post.path) %>"><%= post.title %></a></h3>
                  <% if (post.categories && post.categories.length) { %>
                    <p class="archive-item-meta"><%= post.categories.map(function(category) { return category.name; }).join(' / ') %></p>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty-state"><%= __('ui.no_posts') %></p>
  <% } %>
</section>
